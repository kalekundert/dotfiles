#!/usr/bin/env python3

"""
Find all packages imported in a Python project.

Usage:
    find-imports [<path>]... [-x <exclude>]

Arguments:
    <path>
        The paths to scan for import statements.  Any directories will be 
        scanned recursively for python scripts.  By default, the whole current 
        working directory will be scanned.

Options:
    -x --exclude <path>
        A path to a file containing packages to exclude from the output.  
        Currently, this must be a path to a `pyproject.toml` file.  All 
        mandatory and optional dependencies will be excluded.
"""

import docopt
import re
import tomllib

from glom import glom, flatten
from pathlib import Path

IMPORT_PATTERNS = [
    r'\s*import (\w+)',
    r'\s*from (\w+)(\..*)? import',
]
STDLIB = {
