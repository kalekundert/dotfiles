def iter_paths(paths):
    for path in paths:
        if path.is_dir():
            yield from path.glob('**/*.py')
        else:
            yield path

def parse_pyproject(path):
    with open(path, 'rb') as f:
        pyproject = tomllib.load(f)

    project_name = glom(
            pyproject,
            'project.name',
    )
    project_deps = glom(
            pyproject,
            'project.dependencies',
            default=[],
    )
    optional_deps = glom(
            pyproject,
            'project.optional-dependencies.*',
            default=[],
    )

    deps = flatten([[project_name], project_deps, *optional_deps])
    deps = [
            re.split(r'([~=!<>]\=)|([><])', dep)[0].strip()
            for dep in deps
    ]
    return set(deps)

if __name__ == '__main__':
    args = docopt.docopt(__doc__)

    if path_args := args['<path>']:
        paths = [Path(p) for p in path_args]
    else:
        paths = [Path.cwd()]

    imports = set()

    for path in iter_paths(paths):
        if 'env' in str(path):
            continue
        try:
            text = path.read_text()
        except (FileNotFoundError, UnicodeDecodeError):
            print(f"error: failed to read: {path}")
            continue

        for line in text.splitlines():
            for pat in IMPORT_PATTERNS:
                if m := re.match(pat, line):
                    lib = m.group(1)
                    if lib not in STDLIB:
                        imports.add(lib)

    if args['--exclude']:
        deps = parse_pyproject(args['--exclude'])
        imports -= deps

    for lib in sorted(imports):
        print(lib)





